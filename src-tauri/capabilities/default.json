{
  "$schema": "../gen/schemas/desktop-capability.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "http:default",
    "shell:default",
    "keychain:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        "https://games.roblox.com/**",
        "https://*.roblox.com/**",
        "https://thumbnails.roblox.com/**"
      ]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [{ "schemes": ["roblox-player", "http", "https"] }]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "open-roblox",
          "cmd": "cmd",
          "args": ["/C", "start", { "validator": "^roblox-player:.+" }]
        },
        {
          "name": "launch-sober",
          "cmd": "flatpak",
          "args": ["run", "org.vinegarhq.Sober", "--", { "validator": ".+" }]
        },
        {
          "name": "xdg-open",
          "cmd": "xdg-open",
          "args": [{ "validator": ".+" }]
        }
      ]
    },
    "os:default"
  ]
}
